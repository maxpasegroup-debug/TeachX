model Institution {
  id             String         @id @default(cuid())
  name           String
  logoUrl        String?
  primaryColor   String         @default("#111827")
  secondaryColor String         @default("#64748b")
  address        String?
  phone          String?
  email          String?
  website        String?
  timezone       String         @default("Asia/Kolkata")
  academicYear   String?
  currency       String         @default("INR")
  users          User[]
  settings       Setting[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  branches       Branch[]
  academicYears  AcademicYear[]
  departments    Department[]
  courses        Course[]
  plannerEvents  PlannerEvent[]
  timeSlots      TimeSlot[]
  rooms          Room[]
  classrooms     Classroom[]
  leadSources    CampaignSource[]
  campaigns      Campaign[]
  leads          Lead[]
  applications   Application[]
  admissions     Admission[]
  partners       Partner[]
  questionImports QuestionImport[]
  exams          Exam[]
  feeHeads      FeeHead[]
  feePlans      FeePlan[]
  studentFees   StudentFee[]
  payments      Payment[]
  invoices      Invoice[]
  receipts      Receipt[]
  expenseCategories ExpenseCategory[]
  expenses      Expense[]
  payrolls      Payroll[]
  visitors      Visitor[]
  appointments  Appointment[]
  contentFolders ContentFolder[]
  contentItems   ContentItem[]
  activities     Activity[]
  communications Communication[]
  directConversations DirectConversation[]
  communities    Community[]
  genericDiscussions GenericDiscussion[]
  notificationTemplates NotificationTemplate[]
  activityEvents ActivityEvent[]
  supportTickets SupportTicket[]
  supportReplies SupportReply[]
  featureFlags   FeatureFlag[]
  platformMetrics PlatformMetric[]
  aiConversations AIConversation[]
  aiUsages       AIUsage[]
  promptTemplates PromptTemplate[]
  automationRules AutomationRule[]
  subscriptionPlans SubscriptionPlan[]
  userSubscriptions UserSubscription[]
  wallets        Wallet[]
  walletTransactions WalletTransaction[]
  commerceOrders CommerceOrder[]
  coupons        Coupon[]
  referrals      Referral[]
  commerceInvoices CommerceInvoice[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model User {
  id               String         @id @default(cuid())
  institutionId    String?
  institution      Institution?   @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  email            String         @unique
  name             String
  userType         UserType?
  passwordHash     String?
  status           UserStatus     @default(ACTIVE)
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  rememberToken    String?
  roles            UserRole[]
  profile          Profile?
  teacherProfile   TeacherProfile?
  studentProfile   StudentProfile?
  notifications    Notification[]
  auditLogs        AuditLog[]     @relation("ActorAuditLogs")
  accounts         Account[]
  sessions         Session[]
  resetTokens      PasswordResetToken[]
  facultyBatches   BatchFaculty[]
  studentBatches   BatchStudent[]
  timetableEntries TimetableEntry[] @relation("TimetableFaculty")
  scheduleOverrides DailyScheduleOverride[] @relation("OverrideFaculty")
  classroomAnnouncements ClassroomAnnouncement[] @relation("AnnouncementAuthor")
  materials       StudyMaterial[] @relation("MaterialUploader")
  assignments     Assignment[] @relation("AssignmentCreator")
  assignmentSubmissions AssignmentSubmission[] @relation("SubmissionStudent")
  attendanceRecords AttendanceRecord[] @relation("AttendanceStudent")
  recordings      Recording[] @relation("RecordingUploader")
  liveSessions    LiveSession[] @relation("LiveSessionFaculty")
  learningProgress LearningProgress[] @relation("LearningProgressStudent")
  videoProgress   VideoProgress[] @relation("VideoProgressStudent")
  bookmarks       Bookmark[] @relation("BookmarkStudent")
  studentNotes    StudentNote[] @relation("StudentNoteOwner")
  discussionThreads DiscussionThread[] @relation("DiscussionThreadAuthor")
  discussionReplies DiscussionReply[] @relation("DiscussionReplyAuthor")
  assignedLeads   Lead[] @relation("AssignedExecutive")
  ownedLeadTasks  LeadTask[] @relation("LeadTaskOwner")
  leadActivities  LeadActivity[] @relation("LeadActivityActor")
  guestLeads      Lead[] @relation("LeadGuestUser")
  partnerProfile  Partner?
  admissionsAsStudent Admission[] @relation("AdmissionStudent")
  authoredQuestions Question[] @relation("QuestionAuthor")
  questionImports QuestionImport[]
  createdExams    Exam[] @relation("ExamCreator")
  examAttempts    ExamAttempt[] @relation("ExamAttemptStudent")
  studentFees     StudentFee[] @relation("StudentFeeStudent")
  payments        Payment[] @relation("PaymentStudent")
  invoices        Invoice[] @relation("InvoiceStudent")
  createdContent  ContentItem[] @relation("ContentCreator")
  contentVersions ContentVersion[] @relation("ContentVersionUpdater")
  contentReviews  ContentReview[] @relation("ContentReviewer")
  contentApprovals ContentApproval[] @relation("ContentApprover")
  contentDownloads DownloadHistory[] @relation("ContentDownloadUser")
  contentWatches   WatchHistory[] @relation("ContentWatchUser")
  workspacePreferences WorkspacePreference[]
  userPreferences UserPreference[]
  savedSearches    SavedSearch[]
  dashboardWidgets DashboardWidget[]
  recentItems      RecentItem[]
  favoriteItems    FavoriteItem[]
  notificationPreferences NotificationPreference[]
  activities       Activity[] @relation("ActivityActor")
  parentLinks      ParentChildRelation[] @relation("ParentRelation")
  childLinks       ParentChildRelation[] @relation("ChildRelation")
  communicationsCreated Communication[] @relation("CommunicationCreator")
  communicationRecipients CommunicationRecipient[]
  communicationLogs CommunicationLog[]
  directConversationsCreated DirectConversation[] @relation("DirectConversationCreator")
  directConversationParticipants DirectConversationParticipant[]
  sentDirectMessages DirectMessage[] @relation("DirectMessageSender")
  communitiesCreated Community[] @relation("CommunityCreator")
  communityMemberships CommunityMember[]
  genericDiscussions GenericDiscussion[] @relation("GenericDiscussionAuthor")
  genericDiscussionReplies GenericDiscussionReply[] @relation("GenericDiscussionReplyAuthor")
  notificationTemplatesCreated NotificationTemplate[] @relation("NotificationTemplateCreator")
  activityEvents ActivityEvent[] @relation("ActivityEventActor")
  supportTicketsCreated SupportTicket[] @relation("SupportTicketRequester")
  supportTicketsAssigned SupportTicket[] @relation("SupportTicketAssignee")
  supportReplies SupportReply[] @relation("SupportReplyAuthor")
  aiConversations AIConversation[]
  aiUsages       AIUsage[]
  subscriptions  UserSubscription[]
  wallets        Wallet[]
  walletTransactions WalletTransaction[]
  commerceOrders CommerceOrder[] @relation("CommerceOrderBuyer")
  soldOrderItems CommerceOrderItem[] @relation("CommerceOrderItemSeller")
  commerceInvoices CommerceInvoice[] @relation("CommerceInvoiceBuyer")
  referralsMade  Referral[] @relation("ReferralReferrer")
  referralsUsed  Referral[] @relation("ReferralReferred")
  automationExecutions AutomationExecution[]
  staffProfile    StaffProfile?
  leaveApplications LeaveApplication[] @relation("LeaveApplicant")
  approvedLeaves  LeaveApplication[] @relation("LeaveApprover")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([userType])
}

model Branch {
  id            String       @id @default(cuid())
  institutionId String
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  code          String
  address       String?
  contact       String?
  status        RecordStatus @default(ACTIVE)
  courses       Course[]
  batches       Batch[]
  rooms         Room[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([institutionId, code])
  @@index([institutionId])
}

model AcademicYear {
  id            String             @id @default(cuid())
  institutionId String
  institution   Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime
  endDate       DateTime
  status        AcademicYearStatus @default(PLANNED)
  isCurrent     Boolean            @default(false)
  terms         AcademicTerm[]
  courses       Course[]
  batches       Batch[]
  plannerEvents PlannerEvent[]
  timetableEntries TimetableEntry[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([institutionId, name])
  @@index([institutionId, isCurrent])
}

model AcademicTerm {
  id             String           @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String
  type           AcademicTermType @default(SEMESTER)
  startDate      DateTime
  endDate        DateTime
  order          Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([academicYearId, name])
}

model Department {
  id            String       @id @default(cuid())
  institutionId String
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  code          String?
  status        RecordStatus @default(ACTIVE)
  courses       Course[]
  subjects      Subject[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([institutionId, name])
}

model Course {
  id             String       @id @default(cuid())
  institutionId  String
  institution    Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  name           String
  description    String?
  code           String
  duration       String?
  category       String?
  status         RecordStatus @default(ACTIVE)
  thumbnailUrl   String?
  learningModes  LearningMode[]
  subjects       Subject[]
  batches        Batch[]
  timetableEntries TimetableEntry[]
  classrooms     Classroom[]
  learningProgress LearningProgress[]
  leads          Lead[]
  applications   Application[]
  admissions     Admission[]
  commissionRules PartnerCommission[]
  chapters       Chapter[]
  topics         Topic[]
  questions      Question[]
  exams          Exam[]
  feePlans      FeePlan[]
  studentFees   StudentFee[]
  contentFolders ContentFolder[]
  contentItems   ContentItem[]
  communications Communication[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([institutionId, code])
  @@index([institutionId])
}

model Subject {
  id             String       @id @default(cuid())
  courseId       String
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  name           String
  code           String?
  description    String?
  order          Int          @default(1)
  status         RecordStatus @default(ACTIVE)
  timetableEntries TimetableEntry[]
  scheduleOverrides DailyScheduleOverride[] @relation("OverrideSubject")
  materials      StudyMaterial[]
  assignments    Assignment[]
  learningProgress LearningProgress[]
  chapters       Chapter[]
  topics         Topic[]
  questions      Question[]
  exams          Exam[]
  feePlans      FeePlan[]
  studentFees   StudentFee[]
  contentFolders ContentFolder[]
  contentItems   ContentItem[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([courseId, name])
}

model Chapter {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  name      String
  order     Int      @default(1)
  topics    Topic[]
  questions Question[]
  exams     Exam[]
  contentFolders ContentFolder[]
  contentItems   ContentItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subjectId, name])
}

model Topic {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  name      String
  order     Int      @default(1)
  questions Question[]
  exams     Exam[]
  contentFolders ContentFolder[]
  contentItems   ContentItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subjectId, name])
}

model Batch {
  id             String       @id @default(cuid())
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  courseId       String
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name           String
  capacity       Int          @default(30)
  maximumStrength Int         @default(30)
  startDate      DateTime?
  endDate        DateTime?
  mode           BatchMode    @default(OFFLINE)
  type           BatchType    @default(WEEKDAY)
  status         BatchStatus  @default(UPCOMING)
  faculty        BatchFaculty[]
  students       BatchStudent[]
  timetableEntries TimetableEntry[]
  classroom      Classroom?
  attendanceSessions AttendanceSession[]
  leads          Lead[]
  applications   Application[]
  admissions     Admission[]
  exams          Exam[]
  feePlans       FeePlan[]
  studentFees    StudentFee[]
  contentItems   ContentItem[]
  communications Communication[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([courseId, name])
  @@index([courseId, status])
}

model BatchFaculty {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  facultyId String
  faculty   User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  isLead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([batchId, facultyId])
}

model BatchStudent {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
